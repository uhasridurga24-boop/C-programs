#include <iostream>
#include <stack>
#include <queue>
#include <string>
using namespace std;

bool isPalindrome(string str) {
    stack<char> s;
    queue<char> q;

    for (char ch : str) {
        s.push(ch);
        q.push(ch);
    }

    while (!q.empty()) {
        if (s.top() != q.front()) {
            return false;
        }
        s.pop();
        q.pop();
    }
    return true;
}

int main() {
    string input = "radar";
    if (isPalindrome(input)) cout << input << " is a palindrome.";
    else cout << input << " is not a palindrome.";
    return 0;
}
